{
  "compilerOptions": {
    "target": "ES2022", // matches engines.node >=20.19.0
    "module": "commonjs",
    "lib": ["es2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/"],
  "exclude": ["**/*.spec.ts"]
}
